[colors]
background = #2e3440
background-alt = #3b4252
foreground = #d8dee9
foreground-alt = #d8dee9
primary = #3b4252
secondary = #81a1c1
alert = #ebcb8b

[bar/hdmi]
monitor = HDMI1
width = 100%
height = 2.5%
;height = 20
;offset-x = 1%
;offset-y = 1%
radius = 0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3
line-color = #f00

border-size = 0
border-color = #00000000

padding-left = 0
padding-right = 0

module-margin-left = 1
module-margin-right = 1

font-0 = FiraCode Nerd Font:pixelsize=12:1
font-1 = Symbola:pixelsize=12
;font-0 = Fira Code Nerd Font:pixelsize=10:1
;font-1 = Symbola:pixelsize=10
font-2 = Siji:pixelsize=8;1
font-3 = "Noto Color Emoji:pixelsize=12:style=Regular:scale=7;2"

modules-left = bspwm
modules-center = date
modules-right = github cpu memory pulseaudio wlan battery 

tray-position = none
tray-padding = 2
;tray-background = #0063ff


;wm-restack = bspwm

;override-redirect = true

;scroll-up = bspwm-desknext
;scroll-down = bspwm-deskprev

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

[bar/local]
monitor = eDP1
width = 100%
height = 2.5%
;height = 20
;offset-x = 1%
;offset-y = 1%
radius = 0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3
line-color = #f00

border-size = 0
border-color = #00000000

padding-left = 0
padding-right = 0

module-margin-left = 1
module-margin-right = 1

font-0 = FiraCode Nerd Font:pixelsize=18:1
font-1 = Symbola:pixelsize=18
;font-0 = Fira Code Nerd Font:pixelsize=10:1
;font-1 = Symbola:pixelsize=10
font-2 = Siji:pixelsize=12;1
font-3 = "Noto Color Emoji:pixelsize=18:style=Regular:scale=6"

modules-left = bspwm
modules-center = date
modules-right = github backlight cpu memory pulseaudio wlan battery 

tray-position = none
tray-padding = 2
;tray-background = #0063ff


;wm-restack = bspwm

;override-redirect = true

;scroll-up = bspwm-desknext
;scroll-down = bspwm-deskprev

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

[module/bspwm]
type = internal/bspwm
pin-workspaces = true
fuzzy-match = true

ws-icon-0 = "1;ūüėõ" 
ws-icon-1 = "2;ūüėį"
ws-icon-2 = "3;ūüćÜ"
ws-icon-3 = "4;ūüíĽ"
ws-icon-4 = "5;ūüíĖ"
ws-icon-5 = "6;ūüďĽ"
ws-icon-6 = "7;‚ú®"
ws-icon-7 = "8;ūüźĒ"
ws-icon-8 = "9;ūü™ī"
ws-icon-9 = "0;ūüĎÄ"

label-focused-font = 4
label-urgent-font = 4
label-empty-font = 4
label-dimmed-font = 4
label-occupied-font = 4
label-focused = %icon%
label-focused-foreground = ${colors.alert}
label-focused-background = ${colors.background}
label-focused-underline = ${colors.alert}

label-urgent= %icon%
label-urgent-foreground = ${colors.background}
label-urgent-background = ${colors.alert}

label-empty = %icon%
label-dimmed = %icon%
label-occupied = %icon%

label-separator = "  "
label-separator-foreground = ${colors.background}

[module/backlight]
type = internal/backlight
card = intel_backlight
enable-scroll = true
format-prefix = "ūüí°"
format-prefix-font = 4
format = <label>
label = %percentage%%

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "ūü•Ķ" 
format-prefix-font = 4
format-prefix-foreground = ${colors.foreground}
;format-underline = #f90000
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "ūü§Į"
format-prefix-foreground = ${colors.foreground}
format-prefix-font = 4
;format-underline = #4bffdc
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = wlp0s20f3
interval = 3.0

format-connected = <label-connected>
format-connected-prefix-font = 4
format-connected-prefix = ūüĎĆ
;format-connected-underline = #9f78e1
label-connected = %essid%

format-disconnected = ūüė§
format-disconnected-font = 4
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}


[module/date]
type = internal/date
interval = 5

date =
date-alt = " %d/%m/%Y "

time = %H:%M
time-alt = %H:%M

format-prefix = ūüēĒ
format-prefix-font = 4
format-prefix-foreground = ${colors.foreground}
;format-underline = #0a6cf5

label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume>
label-volume = %percentage%%
format-volume-prefix = ūüĒä
format-volume-prefix-font = 4
label-volume-foreground = ${colors.foreground}
click-right = pavucontrol
label-muted = "ūüĒá "
label-muted-font = 4
label-muted-foreground = ${colors.foreground}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 98

format-charging = <animation-charging> <label-charging>
;format-charging-underline = #ffb52a

format-discharging = <animation-discharging> <label-discharging>
;format-discharging-underline = ${self.format-charging-underline}

format-full-prefix = "ūüí¶"
format-full-prefix-foreground = ${colors.foreground}
format-full-prefix-font = 4
;format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = "ÔČĄ "
ramp-capacity-1 = "ÔČÉ "
ramp-capacity-2 = "ÔČā "
ramp-capacity-3 = "ÔČĀ "
ramp-capacity-4 = "ÔČÄ "
